// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  clerkUserId   String    @unique
  email         String    @unique
  name          String?
  imageUrl      String?
  bio           String?
  experience    Int?
  skills        String[]

  // Relation to IndustryInsight
  industryInsightId String?       @db.ObjectId
  industryInsight   IndustryInsight? @relation(fields: [industryInsightId], references: [id])

  // Relations
  assessments    AssessmentSession[]
  mockInterviews InterviewSession[]
  resume         Resume?
  coverLetter    CoverLetter[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Resume {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  
  // FIX: Added @db.ObjectId
  userId    String   @unique @db.ObjectId 
  user      User     @relation(fields: [userId], references: [id])
  
  content   String 
  atsScore  Float?
  feedback  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AssessmentSession {

  id            String @id @default(auto()) @map("_id") @db.ObjectId

  userId        String @db.ObjectId
  user          User   @relation(fields:[userId], references:[id])

  documentName  String

  status        String @default("ready")

  assessment    Json

  answers       Json?

  evaluation    Json?

  startedAt     DateTime?

  completedAt   DateTime?

  createdAt     DateTime @default(now())

  updatedAt     DateTime @updatedAt

  @@index([userId])

}

model CoverLetter {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  
  // FIX: Added @db.ObjectId
  userId         String   @db.ObjectId 
  user           User     @relation(fields: [userId], references: [id])
  
  content        String
  jobDescription String?
  companyName    String
  jobTitle       String
  status         String   @default("draft")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}

model IndustryInsight {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  industry      String   @unique
  
  // Bi-directional relation to User
  users         User[]

  salaryRanges  Json[]
  growthRate    Float
  demandLevel   String
  topSkills     String[]
  marketOutlook String
  keyTrends     String[]
  recommendedSkills String[]

  lastUpdated   DateTime @default(now())
  nextUpdate    DateTime
}

model InterviewSession {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  
  // FIX: Added @db.ObjectId
  userId         String   @db.ObjectId 
  user           User     @relation(fields: [userId], references: [id])
  
  date           DateTime @default(now())
  jobRole        String?
  companyName    String?
  techStack      String?
  focus          String?    
  difficulty     String?    
  personality    String?    
  
  duration       Int?      // Planned duration (e.g., 15 mins)
  actualDuration Int?      @default(0) // Actual time spent
  
  jobDescription String?
  config         Json
  transcript     Json
  analysis       Json?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}